<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<TabPane fx:id="mainTabPane" prefHeight="700.0" prefWidth="1000.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FarmController">
  <tabs>
    <Tab text="Ma Ferme">
      <content>
        <BorderPane>
          <top>
            <HBox spacing="20" style="-fx-background-color: #2ecc71; -fx-padding: 10;">
               <Label fx:id="walletLabel" style="-fx-text-fill: white; -fx-font-weight: bold;" text="Argent : 500 €" />
               <Label fx:id="levelLabel" style="-fx-text-fill: white;" text="Niveau : 1 (0/100 XP)" />
               <Separator orientation="VERTICAL" />
               <Label fx:id="weatherLabel" text="☀️ Ensoleillé" />
               <Label fx:id="seasonLabel" text="Printemps - Jour 1" />
               <Region HBox.hgrow="ALWAYS" />
               <Button onAction="#saveGame" text="Sauvegarder" />
            </HBox>
          </top>

          <left>
            <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #f4f4f4; -fx-border-color: #ddd;">
               <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-weight: bold;" text="Cultures" />
               <ScrollPane fitToWidth="true" prefWidth="150">
                  <VBox fx:id="seedSelectionBox" spacing="5">
                     </VBox>
               </ScrollPane>
               <Separator />
               <Text text="Outils" />
               <Button fx:id="btnArrosoir" maxWidth="Infinity" text="Arrosoir" />
               <Button fx:id="btnFaux" maxWidth="Infinity" text="Récolte Auto" />
            </VBox>
          </left>

          <center>
            <StackPane>
               <GridPane fx:id="farmGrid" alignment="CENTER" hgap="5" vgap="5" style="-fx-padding: 20;">
                  </GridPane>
            </StackPane>
          </center>

          <right>
            <VBox spacing="10" prefWidth="200" style="-fx-padding: 10; -fx-background-color: #fafafa; -fx-border-color: #ddd;">
               <Label style="-fx-font-weight: bold;" text="Contrats du jour" />
               <VBox fx:id="contractsBox" spacing="10">
                  <Label style="-fx-font-style: italic;" text="Aucun contrat..." />
               </VBox>
            </VBox>
          </right>
        </BorderPane>
      </content>
    </Tab>

    <Tab fx:id="tabGarage" disable="true" text="Garage (Niveau 20)">
      <content>
        <AnchorPane>
           <Label layoutX="400.0" layoutY="300.0" text="Espace verrouillé : Atteignez le niveau 20" />
        </AnchorPane>
      </content>
    </Tab>

    <Tab text="🛠 DEBUG">
      <content>
        <VBox spacing="20" style="-fx-padding: 30;">
           <HBox spacing="10" alignment="CENTER_LEFT">
              <Label text="Économie :" style="-fx-font-weight: bold;"/>
              <Button onAction="#debugAddMoney" text="+ 1000 €" />
              <Button onAction="#debugResetMoney" text="Reset Argent" />
           </HBox>
           <HBox spacing="10" alignment="CENTER_LEFT">
              <Label text="Temps/Météo :" style="-fx-font-weight: bold;"/>
              <Button onAction="#debugFastForward" text="Passer 1 Jour" />
              <ComboBox fx:id="debugWeatherChoice" promptText="Changer Météo" />
           </HBox>
           <HBox spacing="10" alignment="CENTER_LEFT">
              <Label text="Progression :" style="-fx-font-weight: bold;"/>
              <Button onAction="#debugLevelUp" text="+1 Niveau" />
              <Button onAction="#debugUnlockAll" text="Tout débloquer" />
           </HBox>
        </VBox>
      </content>
    </Tab>
  </tabs>
</TabPane>