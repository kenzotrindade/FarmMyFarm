<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controllers.InventoryController"
      spacing="10" style="-fx-padding: 15; -fx-background-color: #f9f9f9; -fx-border-color: #ddd;" prefWidth="220">
    <Label text="📦 Inventaire" style="-fx-font-weight: bold; -fx-font-size: 14;" />
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox fx:id="itemsContainer" spacing="5" />
    </ScrollPane>
    <Button text="VENDRE TOUT" onAction="#handleSellAll" maxWidth="Infinity" 
            style="-fx-background-color: #e67e22; -fx-text-fill: white;" />
</VBox>